        .gallery {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-around;
        }
        .gallery-item {
            margin: 20px;
            text-align: center;
        }
        .gallery img, .gallery video {
            width: 300px; /* Consistent width for images and videos */
            height: 200px; /* Consistent height for images and videos */
            object-fit: cover; /* Ensures the content fits well within the defined dimensions */
            border: 3px solid #ffab91; /* Light peach border */
        }
        /* Adjusted Logo Styling */
        .gallery-item img.logo {
            width: 400px; /* Wider logo */
